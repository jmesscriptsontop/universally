-- LOGIC
local function notify(btn, text)
    local oldText = btn.Text
    btn.Text = text
    task.wait(2)
    btn.Text = oldText
end

CopyBtn.MouseButton1Click:Connect(function()
    if typeof(setclipboard) == "function" then
        setclipboard(GROUP_LINK)
        notify(CopyBtn, "LINK COPIED TO CLIPBOARD!")
    end
end)

JoinBtn.MouseButton1Click:Connect(function()
    local success = false
    if typeof(openbrowser) == "function" then 
        openbrowser(GROUP_LINK) 
        success = true
    elseif typeof(open_url) == "function" then
        open_url(GROUP_LINK)
        success = true
    end
    
    if success then
        notify(JoinBtn, "BROWSER OPENED...")
    else
        if typeof(setclipboard) == "function" then
            setclipboard(GROUP_LINK)
            notify(JoinBtn, "FAILED: LINK COPIED INSTEAD")
        end
    end
end)

DiscBtn.MouseButton1Click:Connect(function()
