-- LOGIC & ANIMATIONS
local function checkGroup()
    local inGroup = false
    pcall(function() inGroup = player:IsInGroup(GROUP_ID) end)

    if inGroup then
        Status.Text = "Verification Successful ✅"
        Status.TextColor3 = Color3.fromRGB(80, 255, 150)
        JoinBtn.Visible = false
        task.wait(1.5)
        TweenService:Create(Main, TweenInfo.new(0.5), {GroupTransparency = 1, Position = UDim2.new(0.5, -175, 0.8, 0)}):Play()
        task.wait(0.5)
        ScreenGui:Destroy()
    else
        Status.Text = "Group Membership Required ❌"
        Status.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
end

